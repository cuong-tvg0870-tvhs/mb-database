// ==========================================================================
// ASSET ACCESS REQUEST — "Yêu cầu cấp quyền tài sản"
// Migration `add_asset_access_request` (additive; KHÔNG đụng AccountProposal ở
// trên — hệ đó chỉ gán tài sản ĐÃ có sẵn trong DB cho user).
//
// Khác biệt cốt lõi: các tài sản ở đây là MỚI, chưa có trong hệ thống. Nhân sự
// của một project đề xuất thêm TKQC/Fanpage/Pixel/Catalog (+ Folder nội bộ),
// admin cấp quyền cho System-User token trên trình quảng cáo Meta, rồi bấm
// "Xác nhận đã phân" → hệ TỰ đọc từng tài sản từ Meta (đọc được = đã cấp thật),
// upsert vào DB rồi auto phân quyền cho cả PROJECT lẫn NGƯỜI ĐƯỢC PHÂN.
//
// Tách `AssetAccessRequestItem` ra bảng riêng để kéo/phân & retry TỪNG tài sản
// độc lập (một id lỗi token không chặn các id còn lại).
// ==========================================================================

enum AssetAccessType {
  AD_ACCOUNT
  FANPAGE
  PIXEL
  CATALOG
  FOLDER // CreativeFolder nội bộ — không kéo từ Meta, chỉ wire ACL
}

enum AssetAccessRequestStatus {
  DRAFT
  SUBMITTED // chờ admin xử lý
  GRANTING_ON_META // admin đang cấp quyền trên trình quảng cáo
  DONE // đã kéo về + phân hết
  PARTIAL // kéo/phân được một phần — còn item lỗi, giữ phiếu mở để retry
  NEED_MORE_INFO // admin báo thiếu thông tin
  CANNOT_GRANT // không cấp được / từ chối
}

enum AssetItemStatus {
  PENDING // chưa xử lý
  FETCHED // đã đọc được từ Meta + upsert DB (nhưng chưa/không phân ACL — vd PIXEL)
  ALLOCATED // đã kéo về + phân ACL xong
  FAILED // đọc Meta lỗi (chưa cấp quyền / sai id) — có fetchError
  SKIPPED
}

model AssetAccessRequest {
  id String @id @default(uuid())

  // Người tạo phiếu đề xuất
  requesterId String
  requester   User   @relation("AssetReqRequester", fields: [requesterId], references: [id], onDelete: Cascade)

  // Người sẽ được phân quyền (mặc định = requester). Cho phép trỏ tới user đã có,
  // hoặc khai email/tên để tự tạo user mới lúc confirm (giống AccountProposal).
  assigneeUserId String?
  assignee       User?   @relation("AssetReqAssignee", fields: [assigneeUserId], references: [id], onDelete: SetNull)
  assigneeEmail  String?
  assigneeName   String?
  employeeId     String?

  // Project nhận tài sản
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  // Thông tin để admin tìm trên trình quảng cáo
  businessId   String? // Business Manager id
  businessName String? // Tên BM sở hữu tài sản (giúp admin nhận diện nhanh)
  // Requester tự đánh dấu ĐÃ chia sẻ tài sản về BM của công ty (BM02) trước khi
  // gửi phiếu → admin biết chỉ cần cấp token, không phải đi xin share nữa.
  sharedToBm   Boolean @default(false)
  note         String? @db.Text // ghi chú requester (link, owner, hoàn cảnh...)

  status        AssetAccessRequestStatus @default(SUBMITTED)
  adminFeedback String?                  @db.Text

  processedById String?
  processedBy   User?     @relation("AssetReqProcessor", fields: [processedById], references: [id], onDelete: SetNull)
  processedAt   DateTime?

  items AssetAccessRequestItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([requesterId])
  @@index([assigneeUserId])
  @@index([projectId])
  @@index([status])
}

model AssetAccessRequestItem {
  id        String             @id @default(uuid())
  requestId String
  request   AssetAccessRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  type   AssetAccessType
  metaId String // id tài sản trên Meta (hoặc CreativeFolder.id nếu type=FOLDER)
  name   String? // tên khai báo / tên lấy về từ Meta

  // Danh sách người được cấp quyền cho RIÊNG tài sản này + mức quyền từng người
  // (giống màn "Phân quyền Tài nguyên" của dự án). Mảng JSON:
  // [{ userId, name, permission }]. permission là enum theo type:
  //   AD_ACCOUNT → MemberRole (VIEWER/EDITOR); FANPAGE/CATALOG → VIEW/EDIT/ADMIN;
  //   FOLDER → VIEW/EDIT; PIXEL → không cấp ACL (quyền đi theo TKQC).
  // Khi admin confirm: tài sản vào dự án + từng user được cấp đúng mức ngay.
  grants Json?

  status     AssetItemStatus @default(PENDING)
  fetchError String?         @db.Text
  fetchedAt  DateTime?

  // Người xử lý ở Business Manager tự tích "đã phân quyền cho token trên BM cho
  // tài sản này". Tách khỏi status (do hệ đọc Meta): item đã tick nhưng VẪN lỗi
  // (#200/#10) = việc BM đã xong nhưng phía token hệ thống còn vướng → admin hệ
  // thống ưu tiên vào soi. Lưu kèm ai/khi (denormalize tên, khỏi join User).
  grantedOnBm       Boolean   @default(false)
  grantedOnBmAt     DateTime?
  grantedOnBmById   String?
  grantedOnBmByName String?

  createdAt DateTime @default(now())

  @@index([requestId])
  @@index([type, metaId])
}

// ==========================================================================
// AUTOMATION (Birch-style rule engine)
// Added in migration `add_automation`. Không chạm vào models legacy ở trên.
// ==========================================================================

enum AutomationRuleLevel {
  AD_ACCOUNT
  CAMPAIGN
  ADSET
  AD
}

enum AutomationScheduleType {
  INTERVAL
  SPECIFIC
}

enum AutomationTaskKind {
  START
  PAUSE
  DUPLICATE
  NOTIFY
  INCREASE_BUDGET
  DECREASE_BUDGET
  SET_SPENDING_LIMITS
  REMOVE_SPENDING_LIMITS
  INCREASE_SPENDING_LIMITS
  DECREASE_SPENDING_LIMITS
  ADD_TO_NAME
  REMOVE_FROM_NAME
  REPLACE_TEXT_IN_NAME
}

enum AutomationGroupOperator {
  AND
  OR
}

enum AutomationCompareType {
  VALUE
  METRIC
  RANKING
  TIME
}

model AutomationCategory {
  id       String @id @default(uuid())
  name     String
  position Int    @default(0)

  // Project chủ sở hữu (do dự án khác ghi trên DB dùng chung). Scalar-FK only —
  // KHÔNG @relation sang Project để tránh coupling migration chéo team. null =
  // category top-level (cùng cấp với project trên sidebar, giữ hành vi cũ).
  projectId String?

  // Nhân bản danh mục chạy nền (BullMQ). null = category thường (mọi row cũ).
  // Khi PENDING/RUNNING, FE hiện spinner + màn "đang nhân bản" thay cây folder và
  // BE từ chối rename/move/reorder (nhưng vẫn cho xoá bản FAILED).
  cloneStatus   AutomationCategoryCloneStatus?
  cloneError    String?
  cloneSourceId String?

  folders          AutomationFolder[]
  rules            AutomationRule[]
  customMetrics    CustomMetric[]
  customTimeframes AutomationCustomTimeframe[]

  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@index([createdById, position])
  @@index([projectId])
}

enum AutomationCategoryCloneStatus {
  PENDING
  RUNNING
  DONE
  FAILED
}

model AutomationFolder {
  id       String @id @default(uuid())
  name     String
  position Int    @default(0)

  categoryId String
  category   AutomationCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  parentId String?
  parent   AutomationFolder?  @relation("AutomationFolderTree", fields: [parentId], references: [id], onDelete: Cascade)
  children AutomationFolder[] @relation("AutomationFolderTree")

  rules AutomationRule[]

  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@index([categoryId, parentId, position])
  @@index([parentId])
}

model AutomationRule {
  id                  String                  @id @default(uuid())
  name                String
  status              AutomationRuleStatus    @default(DRAFT)
  level               AutomationRuleLevel
  timezone            String
  notifyErrorsOnly    Boolean                 @default(false)
  filterGroupOperator AutomationGroupOperator @default(OR)
  position            Int                     @default(0)

  useAdSetAttributionWindow Boolean @default(true)
  attributionWindow         String?

  // When true, matched items are auto-confirmed by the runner and pushed to the
  // executor in the same tick — no manual confirm step. Default false preserves
  // the manual-confirm behaviour for every existing rule.
  autoExecute Boolean @default(false)

  // False while the rule's insight cache is still being seeded after activation —
  // the runner holds it in "Đang nạp dữ liệu" (no evaluation) and drives the
  // backfill, flipping to true (and starting real runs) once the cache is
  // complete. Default true so existing rules keep running (only NEW activations
  // that need seeding start at false).
  dataReady Boolean @default(true)

  categoryId String
  category   AutomationCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  folderId String?
  folder   AutomationFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)

  schedule     AutomationSchedule?
  filterGroups AutomationFilterGroup[]
  tasks        AutomationTask[]
  adAccounts   AutomationRuleAdAccount[]
  notifyUsers  AutomationRuleNotifyUser[]
  runs         AutomationRuleRun[]

  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@index([categoryId, folderId, position])
  @@index([createdById, updatedAt(sort: Desc)])
  @@index([status, updatedAt(sort: Desc)])
}

enum AutomationRuleStatus {
  DRAFT
  ACTIVE
  PAUSED
}

// Junction tới legacy Account: scalar FK only (không @relation sang Account để không
// phải thêm back-relation vào model Account cũ).
model AutomationRuleAdAccount {
  ruleId    String
  accountId String

  rule AutomationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@id([ruleId, accountId])
  @@index([accountId])
}

/// User-defined custom timeframe (Days range 0..90, hoặc Hours range 0..24).
/// Lưu offsets thay vì absolute timestamps — runner resolve relative tới `now`
/// theo ad account timezone qua `resolveCustomTimeframeWindow`.
/// Rule reference qua chuỗi `"custom:<id>"` trong AutomationTaskCondition.params.timeframe.
/// Scope theo `AutomationCategory` — mọi rule trong category đó share & edit
/// được. Cascade delete khi xoá category.
model AutomationCustomTimeframe {
  id          String             @id @default(uuid())
  name        String
  kind        String // "days" | "hours" — validate ở zod
  fromOffset  Int // L position; 0 = today/current hour
  toOffset    Int // R position; fromOffset <= toOffset; max 90 (days) hoặc 24 (hours)
  categoryId  String
  category    AutomationCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdById String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([categoryId])
}

enum CustomMetricScope {
  GLOBAL
  AD_ACCOUNT
  CATEGORY
  USER
}

enum CustomMetricFormat {
  numeric
  currency
  percentage
}

/// User-defined custom metric: a formula combining native Meta metrics + numbers
/// + arithmetic operators (vd ROAS = action_values / spend). `formula` lưu token
/// array JSON (mirror Bir.ch): [{ type, value, key }] với type ∈ variable|number|operator.
/// Rule reference qua chuỗi `"custom_metric:<id>"` trong AutomationTaskCondition.params.metric.
/// Scope GLOBAL → accountId/categoryId null (mọi user thấy);
/// AD_ACCOUNT → accountId bắt buộc; CATEGORY → categoryId bắt buộc (toàn rule trong category đó thấy).
/// `accountId`/`createdById` là scalar FK (không @relation back-ref, theo pattern AutomationCustomTimeframe).
model CustomMetric {
  id          String              @id @default(uuid())
  name        String // min(1) max(50)
  description String? // max(200)
  format      CustomMetricFormat  @default(numeric)
  scope       CustomMetricScope
  formula     Json // FormulaToken[]
  accountId   String? // bắt buộc khi scope=AD_ACCOUNT, null khi khác
  categoryId  String? // bắt buộc khi scope=CATEGORY, null khi khác
  category    AutomationCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdById String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([accountId])
  @@index([categoryId])
  @@index([scope])
  @@map("custom_metrics")
}

// Junction tới legacy User: scalar FK only.
