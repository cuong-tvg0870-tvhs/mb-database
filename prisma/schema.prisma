  evaluatedAt DateTime  @default(now())
  detectedAt  DateTime?
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status, evaluatedAt(sort: Desc)])
  @@map("ad_fatigue_state")
}

