// --- MODELS ---
model TemplateCampaign {
  id   String @id @default(cuid())
  name String
  data Json?

  reference_id String?
  reference    SystemCampaign? @relation(fields: [reference_id], references: [id])

  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  automationHistories DraftAutomationHistory[]

  @@index([name])
  @@index([reference_id])
  @@index([createdById, createdAt(sort: Desc)])
}

enum DraftAutomationRunStatus {
  SUCCESS
  SKIPPED
  FAILED
}

enum DraftAutomationPublishMode {
  DRAFT_ONLY
  PUBLISH_IMMEDIATELY
}

model DraftAutomationHistory {
  id String @id @default(cuid())

  templateId String
  template   TemplateCampaign @relation(fields: [templateId], references: [id], onDelete: Cascade)

  templateName      String
  creatorId         String?
  creatorName       String?
  creatorEmployeeId String?
  folderId          String?

  status DraftAutomationRunStatus
  reason String?

  publishRequested Boolean                    @default(false)
  publishMode      DraftAutomationPublishMode @default(DRAFT_ONLY)
  publishResult    Json?

  conditionSummary    Json?
  steps               Json?
  selectedAssets      Json?
  generatedCampaignId String?
  error               String?

  startedAt  DateTime  @default(now())
  finishedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([templateId, createdAt(sort: Desc)])
  @@index([creatorId, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
  @@index([publishRequested, createdAt(sort: Desc)])
}

model SystemCampaign {
  id      String  @id @default(cuid())
  data    Json?
  meta_id String?
  cid     String?

  // Snapshot của payload đã đẩy lên Meta ở lần publish THÀNH CÔNG gần nhất. Re-publish
  // diff bản nháp hiện tại với snapshot này (thay vì với trạng thái live) → chỉ đẩy
  // field user thật sự sửa, không đè thiết lập chỉnh tay trên Ads Manager. null = chưa
  // publish lần nào (hoặc draft cũ) → fallback diff-vs-live cho 1 lần rồi tự lành.
  publishedSnapshot Json?

  status Status @default(DRAFT)

  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  accountId String?
  account   Account?      @relation(fields: [accountId], references: [id])
  ad_sets   SystemAdSet[]

  is_template Boolean? @default(false)

  createdByAutomation    Boolean                    @default(false)
  automationTemplateId   String?
  automationTemplateName String?
  automationPublishMode  DraftAutomationPublishMode @default(DRAFT_ONLY)

  campaign_name        String?
  campaign_objective   String?
  campaign_budgetType  String?
  campaign_budget      Int?
  campaign_bidStrategy String?
  campaign_bidAmount   Int?
  campaign_CBO         Boolean?
  campaigns            Campaign[]
  templateCampaigns    TemplateCampaign[]

  errors           Json?
  isPublishing     Boolean          @default(false)
  hasMetaChanges   Boolean          @default(true)
  publishHistories PublishHistory[]

  @@index([status])
  @@index([createdById, createdAt(sort: Desc)])
  @@index([createdByAutomation, createdAt(sort: Desc)])
  @@index([automationTemplateId, createdAt(sort: Desc)])
  @@index([automationPublishMode, createdAt(sort: Desc)])
}

model SystemAdSet {
  id      String  @id @default(cuid())
  data    Json?
  meta_id String?

  // Xem SystemCampaign.publishedSnapshot.
  publishedSnapshot Json?

  status Status @default(DRAFT)

  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  campaignId String?
  campaign   SystemCampaign? @relation(fields: [campaignId], references: [id])

  accountId String?
  account   Account? @relation(fields: [accountId], references: [id])

  ads SystemAd[]

  adset_name         String?
  adset_optimization String?
  adset_budgetType   String?
  adset_budget       Int?
  adset_bidStrategy  String?
  adset_bidAmount    Int?

  @@index([status])
  @@index([createdById, createdAt(sort: Desc)])
}

model SystemAd {
  id      String  @id @default(cuid())
  data    Json?
  meta_id String?

  // Xem SystemCampaign.publishedSnapshot. Bao gồm cả creative đã đẩy để phát hiện
