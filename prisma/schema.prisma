  startedAt  DateTime  @default(now())
  finishedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([templateId, createdAt(sort: Desc)])
  @@index([draftAutomationId, createdAt(sort: Desc)])
  @@index([creatorId, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
  @@index([publishRequested, createdAt(sort: Desc)])
}

// =============================================================================
// DRAFT AUTOMATION (thực thể "tự động hóa lên camp theo template") — NHÓM MỚI.
// -----------------------------------------------------------------------------
// KHÁC hoàn toàn cụm AutomationRule* (Care Ads: tối ưu camp đang chạy). Đây là
// "1 template → NHIỀU lượt tự động": mỗi DraftAutomation trỏ tới 1 TemplateCampaign
// có sẵn (sourceType=TEMPLATE) + nguồn content + lịch + điều kiện; runner mb-batch
// quét các bản ACTIVE để DÙNG LẠI engine dựng-nháp hiện có. sourceType=QUICK_CONFIG
// dành cho phase sau (nguồn = thiết lập nhanh, không cần template).
// Migration additive: bảng mới + cột FK nullable trên DraftAutomationHistory —
// không phá dữ liệu/hành vi cũ.
// =============================================================================
enum DraftAutomationSourceType {
  TEMPLATE
  QUICK_CONFIG
}

enum DraftAutomationScheduleType {
  INTERVAL
  CRON
}

enum DraftAutomationRunMode {
  LOOP
  ONCE
}

enum DraftAutomationStatus {
  ACTIVE
  PAUSED
  COMPLETED
}

model DraftAutomation {
  id          String  @id @default(cuid())
  name        String
  description String?

  // Nguồn dựng nháp. TEMPLATE = từ mẫu có sẵn (hiện tại). QUICK_CONFIG = phase sau.
  sourceType  DraftAutomationSourceType @default(TEMPLATE)
  templateId  String?
  template    TemplateCampaign?         @relation(fields: [templateId], references: [id], onDelete: Cascade)
  quickConfig Json?

  // Nguồn content + điều kiện chọn nội dung. Chi tiết linh hoạt trong `conditions`
  // (nameRule / cidRequired / assetCreatedAfter / videoCount / imageCount / grouping…)
  // để tinh chỉnh KHÔNG cần migration; engine dựng-nháp đọc từ đây.
  folderId   String?
  conditions Json?

  // Lịch chạy.
  scheduleType    DraftAutomationScheduleType @default(INTERVAL)
  intervalMinutes Int?
  cronExpression  String?
  timezone        String?
  runMode         DraftAutomationRunMode      @default(LOOP)

  /// Lịch dạng rule-builder — CÙNG shape với `AutoLaunchRule.schedule` và
  /// `CampaignRuleTemplate.config.schedule`:
  ///   { type:"INTERVAL"|"SPECIFIC", interval?, specificSlots?, useDateRange?, dateFrom?, dateTo? }
  /// Có cột riêng vì lưới SPECIFIC (7 ngày × 24 giờ, sub-slot 15/30/45') KHÔNG nén hết
  /// được về một chuỗi cron — mỗi ngày có thể một khung phút khác nhau.
  ///
  /// NULL = automation cũ, vẫn chạy bằng scheduleType/intervalMinutes/cronExpression.
  /// Reader (mb-batch computeNextRunAt + mb-ads runNow) đọc cột này TRƯỚC, thiếu thì
  /// fallback cột phẳng — nên writer cũ chưa deploy không vỡ.
  schedule Json?

  // Chế độ đăng — mặc định chỉ tạo nháp (an toàn). Dùng lại enum sẵn có.
  publishMode DraftAutomationPublishMode @default(DRAFT_ONLY)

  status DraftAutomationStatus @default(ACTIVE)

  // Theo dõi lần chạy để hiển thị cho marketer (gần nhất / kế tiếp / lý do "đang gom").
  lastRunAt     DateTime?
  nextRunAt     DateTime?
  lastRunStatus DraftAutomationRunStatus?
  lastRunReason String?
  runCount      Int                       @default(0)

  // Trần an toàn (additive): số lượt chạy tối đa. Đạt trần → tự chuyển COMPLETED, ngừng
  // lịch. null = không giới hạn. Enforce ở entity scheduler (mb-batch) + runNow (mb-ads)
  // TRƯỚC khi dựng/đăng nháp.
  maxRuns Int?

  // Khóa chạy NGUYÊN TỬ chống chồng lượt: cron-tick trùng "Chạy ngay", hoặc mb-batch
  // multi-replica. Claim bằng updateMany có điều kiện (runLockedAt null hoặc quá hạn
  // STUCK); giải phóng khi xong. null = đang rảnh.
  runLockedAt DateTime?

  // Bản nháp "đang gom dở" của CHÍNH row này — thay heuristic template+creator+folder
  // (vốn có thể latch nhầm nháp của automation khác cùng mẫu). null = chưa có nháp dở.
  inProgressDraftId String?

  // accountId / createdById dạng chuỗi (không FK) theo đúng quy ước folderId/creatorId
  // ở DraftAutomationHistory.
  accountId   String?
  createdById String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  histories DraftAutomationHistory[]

  @@index([status, nextRunAt])
  @@index([templateId, createdAt(sort: Desc)])
  @@index([accountId, createdAt(sort: Desc)])
  @@index([createdById, createdAt(sort: Desc)])
}

model SystemCampaign {
  id      String  @id @default(cuid())
  data    Json?
  // @unique = lưới an toàn tầng DB chống publish trùng: không cho 2 bản ghi
  // SystemCampaign cùng trỏ về 1 campaign Meta (Postgres cho phép nhiều NULL).
  meta_id String? @unique
  cid     String?

  // Snapshot của payload đã đẩy lên Meta ở lần publish THÀNH CÔNG gần nhất. Re-publish
  // diff bản nháp hiện tại với snapshot này (thay vì với trạng thái live) → chỉ đẩy
  // field user thật sự sửa, không đè thiết lập chỉnh tay trên Ads Manager. null = chưa
  // publish lần nào (hoặc draft cũ) → fallback diff-vs-live cho 1 lần rồi tự lành.
  publishedSnapshot Json?

  status Status @default(DRAFT)

  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  accountId String?
  account   Account?      @relation(fields: [accountId], references: [id])
  ad_sets   SystemAdSet[]

  is_template Boolean? @default(false)

  createdByAutomation    Boolean                    @default(false)
  automationTemplateId   String?
  automationTemplateName String?
  automationPublishMode  DraftAutomationPublishMode @default(DRAFT_ONLY)

  campaign_name        String?
  campaign_objective   String?
  campaign_budgetType  String?
  campaign_budget      Int?
  campaign_bidStrategy String?
  campaign_bidAmount   Int?
  campaign_CBO         Boolean?
  campaigns            Campaign[]
  templateCampaigns    TemplateCampaign[]

  errors           Json?
  isPublishing     Boolean          @default(false)
  // Mốc chiếm cờ isPublishing gần nhất. Chống 2 lỗi: (1) race re-publish — claim
  // còn mới (<20') thì isPublishStuck không được gỡ cờ dù PublishHistory mới nhất
  // là của lần trước; (2) mb-batch tự gỡ khóa kẹt (pod crash sau claim) sau 20'.
  publishClaimedAt DateTime?
  hasMetaChanges   Boolean          @default(true)
  publishHistories PublishHistory[]

  @@index([status])
  @@index([createdById, createdAt(sort: Desc)])
  @@index([createdByAutomation, createdAt(sort: Desc)])
  @@index([automationTemplateId, createdAt(sort: Desc)])
  @@index([automationPublishMode, createdAt(sort: Desc)])
}

