model AutomationTaskGroup {
  id     String         @id @default(uuid())
  taskId String
  task   AutomationTask @relation("AutomationTaskAllGroups", fields: [taskId], references: [id], onDelete: Cascade)

  rootForTaskId String?         @unique
  rootForTask   AutomationTask? @relation("AutomationTaskRoot", fields: [rootForTaskId], references: [id], onDelete: Cascade)

  parentGroupId String?
  parentGroup   AutomationTaskGroup?  @relation("AutomationGroupTree", fields: [parentGroupId], references: [id], onDelete: Cascade)
  childGroups   AutomationTaskGroup[] @relation("AutomationGroupTree")

  conditions AutomationTaskCondition[]

  operator AutomationGroupOperator @default(AND)
  position Int                     @default(0)

  @@index([taskId, parentGroupId, position])
}

model AutomationTaskCondition {
  id          String                @id @default(uuid())
  groupId     String
  group       AutomationTaskGroup   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  compareType AutomationCompareType @default(VALUE)
  params      Json
  position    Int                   @default(0)

  @@index([groupId, position])
}

// ==========================================================================
// AUTOMATION RUNNER LOG (Bir.ch-style scan & log)
// ==========================================================================

enum AutomationRuleRunStatus {
  RUNNING
  COMPLETED
  FAILED
  SKIPPED_OVERLAP
  SKIPPED_OUT_OF_DATE_RANGE
  // Proactively skipped this tick because the ad account was near its Meta
  // rate/insights-throttle limit (or over the per-account concurrency cap). A
  // HEALTHY skip, not a failure: the next tick retries. Running fewer times but
  // succeeding beats running every tick and failing on #4.
  SKIPPED_RATE_LIMIT
  // The job sat in the queue past its usefulness (backlog) and only reached a
  // worker long after `scheduledFor`. Evaluating it would spend Meta calls to
  // act on stale intent, so it is dropped instead — visibly, not silently.
  SKIPPED_STALE
}

enum AutomationRuleRunItemStatus {
  NOT_MATCHED // entity passed filter group but no task condition matched
  PENDING
  CONFIRMED
  REJECTED
  EXPIRED
  EXECUTED
  FAILED
  SKIPPED // handler decided no API call needed (cap reached, frequency limit, CBO/ABO mismatch, …)
}

/// Một AutomationRuleRun = 1 lần (rule × ad account) được scheduler fire.
model AutomationRuleRun {
  id String @id @default(uuid())

  ruleId String
  rule   AutomationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  // Scalar FK only sang Account (model ngoài block automation)
  accountId String

  scheduledFor DateTime
  startedAt    DateTime?
  finishedAt   DateTime?

  // Idempotency guard: `ruleId:accountId:<aligned scheduledFor ISO>`, set only on
  // real runs (not SKIPPED_OVERLAP). NULL on legacy/skip rows — Postgres treats
  // NULLs as distinct, so the unique index only enforces one real run per window.
  dedupeKey String?

  status AutomationRuleRunStatus @default(RUNNING)

  entitiesScanned Int @default(0)
  matchedCount    Int @default(0)
  errorsCount     Int @default(0)

  errorMessage String?
  ruleSnapshot Json?

  items AutomationRuleRunItem[]

  createdAt DateTime @default(now())

  @@unique([dedupeKey])
  @@index([ruleId, scheduledFor(sort: Desc)])
  @@index([accountId, scheduledFor(sort: Desc)])
  @@index([status, scheduledFor(sort: Desc)])
}

/// Mỗi entity match 1 task = 1 row, lưu snapshot + change preview cho UI log-detail.
model AutomationRuleRunItem {
  id String @id @default(uuid())

  runId String
  run   AutomationRuleRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  // Nullable for NOT_MATCHED rows (entity passed filter but no task condition matched)
  taskId   String?
  task     AutomationTask?     @relation(fields: [taskId], references: [id], onDelete: SetNull)
  taskKind AutomationTaskKind?

  level       AutomationRuleLevel
  // Scalar — entityId là Campaign.id / AdSet.id / Ad.id (3 bảng ngoài block automation)
  entityId    String
  entityName  String
  parentLabel String?

  status AutomationRuleRunItemStatus @default(PENDING)

  snapshot      Json
  changePreview Json
  evaluation    Json?

  matchedConditionSummary String?

  // Scalar FK only sang User (model ngoài block automation)
  confirmedAt   DateTime?
  confirmedById String?
  executedAt    DateTime?
  errorMessage  String?

  /// Number of times the Meta executor has attempted this item — increments on
  /// every retry. Used by the processor for backoff and for FE diagnostics.
  executionAttempts Int @default(0)

  /// Structured Meta API error captured on the most recent attempt (code,
  /// subcode, fbtrace, user/developer messages). Null while item is healthy.
  executionError Json?

  /// `fbtrace_id` from the Meta response; surfaced in FE tooltips so support
  /// can correlate with Meta's own logs.
  metaTraceId String?

  /// Comma-joined Meta async request-set id(s) for an in-flight deep_copy
  /// duplicate submitted via `asyncbatch`. NULL for every other item. While set
  /// the item keeps status CONFIRMED but is EXCLUDED from execution and polled
  /// for completion instead — cleared back to NULL when finalised (EXECUTED /
  /// FAILED). Guarantees a partial/failed async copy is never reported EXECUTED.
  asyncRequestIds   String?
  /// Number of times the async-copy poller has checked this item; caps polling
  /// so a stuck async request eventually finalises FAILED ("timeout").
  asyncPollAttempts Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([runId])
  @@index([entityId])
  @@index([taskId])
  @@index([status, createdAt(sort: Desc)])
}

// ==========================================================================
// AUTOMATION INSIGHT CACHE
// Persistent historical insight cache để giảm tải Meta API.
// Granularity = apiLevel (adset|ad); rollup lên campaign chạy ở read-time.
// Scalar accountId (không @relation sang Account legacy). Migration:
// `add_automation_insight_cache` (raw SQL — KHÔNG dùng `prisma migrate dev`).
// ==========================================================================

enum AutomationInsightApiLevel {
  ADSET
  AD
}

enum AutomationInsightBackfillStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  /// Throttle / circuit-open wait — healthy, auto-resuming (NOT an error).
  DEFERRED
  /// Real (non-throttle) error — auto-retrying with capped exponential backoff.
  RETRYING
}

/// Daily settled insight bucket (1 dòng/entity/ngày). Chỉ lưu ngày đã "đóng
/// băng" (date < boundary B = today − freezeDays). `metrics` (Json) giữ raw
/// additive inputs cần cho merge (spend/impressions/clicks/inline_link_clicks/
/// outbound_clicks/results + actions[]/action_values[]/video_*_watched_actions).
/// KHÔNG lưu ratio (recompute từ input) và KHÔNG lưu reach/frequency (dedup
/// theo cửa sổ → cộng ngày sẽ sai). Một ngày fetch DUY NHẤT 1 lần (immutable).
model AutomationInsightDaily {
  id        String                    @id @default(uuid())
  accountId String
  apiLevel  AutomationInsightApiLevel
  entityId  String
  date      String // YYYY-MM-DD (date_start == date_stop)
  metrics   Json
  createdAt DateTime                  @default(now())

  @@unique([accountId, apiLevel, entityId, date])
  @@index([accountId, apiLevel, date])
}

/// Tiến độ/observability của backfill per (account, apiLevel). KHÔNG phải nguồn
/// sự thật về coverage — nguồn sự thật là các ngày thực có trong
/// AutomationInsightDaily. Job gap-driven tự reconcile required vs present.
model AutomationInsightBackfillState {
  id                  String                          @id @default(uuid())
  accountId           String
  apiLevel            AutomationInsightApiLevel
  status              AutomationInsightBackfillStatus @default(PENDING)
  targetSinceDate     String
  oldestSettledDate   String?
  lastSettledDate     String?
  lastRevalidatedAt   DateTime?
  /// Recent-window shared cache (P0-a): the background refresher re-fetches the
  /// still-volatile `[today-freeze .. today]` days into the daily table every
  /// ~AUTOMATION_INSIGHT_RECENT_REFRESH_MIN minutes so rules read them from DB
  /// instead of a live Meta query. `recentThroughDate` = the last day covered
  /// (= today at refresh); `lastRecentRefreshAt` = when it last ran. The read
  /// path serves the volatile zone from DB only while this is fresh (within
  /// 2× the cadence) — otherwise it falls back to the live path (fail-safe).
  recentThroughDate   String?
  lastRecentRefreshAt DateTime?
  /// Last time an ACTIVE rule (run or warmer) confirmed this (account, apiLevel)
  /// is still in use. The maintain scheduler skips states whose lastEvaluatedAt
  /// is null or older than AUTOMATION_INSIGHT_STALE_DAYS so deleted/paused rules
  /// stop being backfilled forever.
  lastEvaluatedAt     DateTime?
  errorMessage        String?
  /// Auto-retry bookkeeping (self-rescheduling seed). retryCount = consecutive
  /// real-error count driving the backoff exponent (reset to 0 on success);
  /// nextRetryAt = when the delayed job fires (throttle defer OR real-error
  /// retry); waitReason = the defer/retry reason for the diagnostics screen;
  /// phase = durable 'daily' | 'deep' (Redis SeedProgress is ephemeral).
  retryCount          Int                             @default(0)
  nextRetryAt         DateTime?
  waitReason          String?
  phase               String?
  /// Structured last-error detail for HTTP-400 root-causing (Graph code/subcode/
  /// fbtrace/HTTP status) + a redacted request context snapshot.
  lastErrorCode       Int?
  lastErrorSubcode    Int?
  lastErrorFbtrace    String?
  lastErrorHttpStatus Int?
  lastErrorAt         DateTime?
  lastErrorContext    Json?
  updatedAt           DateTime                        @updatedAt

  @@unique([accountId, apiLevel])
  @@index([nextRetryAt])
}

/// (PHASE 2) Aggregate đóng băng cho quá khứ sâu của timeframe `maximum`
/// (lifetime): gộp các ngày [creation .. throughDate] vào 1 dòng để khỏi lưu
/// daily cho toàn bộ lifetime. `maximum` = deepAggregate + Σ daily + live.
model AutomationInsightDeepAggregate {
  id          String                    @id @default(uuid())
  accountId   String
  apiLevel    AutomationInsightApiLevel
  entityId    String
  throughDate String
  metrics     Json
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt

  @@unique([accountId, apiLevel, entityId])
}

/// Latest Meta rate-limit usage observed from response headers, persisted per
/// (scope, bucket) so the per-account limit/throttle state is queryable (the
/// Redis snapshot only lives ~1h and can't be listed). `scope` = Meta account id
/// or the sentinel `__app__`; `bucket` = ads_management | ads_insights | app.
/// `maxPct` = worst of call_count/cputime/total_time (0-100); `regainSec` =
/// estimated_time_to_regain_access. Upserted (latest wins), throttled ~1/min.
model AutomationMetaUsage {
  id           String   @id @default(uuid())
  scope        String
  bucket       String
  maxPct       Float    @default(0)
  callCountPct Float    @default(0)
  cpuTimePct   Float    @default(0)
  totalTimePct Float    @default(0)
  regainSec    Int      @default(0)
  tier         String?
  observedAt   DateTime
  updatedAt    DateTime @updatedAt

  @@unique([scope, bucket])
  @@index([scope])
}

enum MetaConnectionStatus {
  ACTIVE
  REVOKED
  INVALID
}

model MetaConnection {
  id String @id @default(uuid())

  /// Scalar FK to User (User lives outside the automation block, keep relation lightweight).
  userId String @unique

  /// AES-256-GCM ciphertext envelope of the long-lived Meta access token.
  encryptedAccessToken String

  /// "SYSTEM_USER" for MVP; "USER" reserved for future OAuth flow.
  tokenType String @default("SYSTEM_USER")

  fbUserId     String?
  fbBusinessId String?
  scopes       String[] @default([])

  status         MetaConnectionStatus @default(ACTIVE)
  lastVerifiedAt DateTime?

  accounts Account[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

// ==========================================================================
// CAMPAIGN RULE ENGINE (MB-owned)
// --------------------------------------------------------------------------
// Rule-engine kiểu Bir.ch/Care Ads NHƯNG là bảng RIÊNG của MB, tiền tố
// `campaign_rule_*`. Cách ly HOÀN TOÀN khỏi block `Automation*` phía trên vì
// Care Ads đang chạy live trên CÙNG một Postgres (schema public) — nếu ghi
// chung bảng, runner Care Ads sẽ nuốt rule của MB và ngược lại.
//
// Điểm khác Automation* (đơn giản hoá + tái sử dụng được):
//   - Bỏ category/folder. Thay bằng scalar FK `accountId` (bắt buộc) + `campaignId`
//     (tuỳ chọn) để "pin" rule vào 1 campaign khi mở từ campaign detail. `campaignId`
//     null = rule phủ cả ad account (tái dùng ở scope rộng hơn về sau).
//   - Mỗi rule gắn 1 ad account (không junction đa-account) — đủ cho use case
//     campaign detail; muốn đa-account sau này thì thêm junction additive.
//   - Cây điều kiện + task + schedule + run/run-item GIỮ NGUYÊN shape để engine
//     đủ tổng quát cho mọi action (DUPLICATE/scale, ±budget, START/PAUSE…).
//
// Enum RIÊNG (tiền tố CampaignRule*) — KHÔNG dùng chung enum Automation* của Care
// Ads để cụm này tự tiến hoá độc lập. CampaignRuleTaskKind là SUPERSET: gồm 13
// action gốc + 2 action MB-native (BUDGET_SCHEDULE_BUMP, LAUNCH_FROM_TEMPLATE) mà
// enum Care Ads không có.
// ==========================================================================

enum CampaignRuleStatus {
  DRAFT
  ACTIVE
  PAUSED
}

enum CampaignRuleLevel {
  AD_ACCOUNT
  CAMPAIGN
  ADSET
  AD
}

enum CampaignRuleScheduleType {
  INTERVAL
  SPECIFIC
}

enum CampaignRuleGroupOperator {
  AND
  OR
}

enum CampaignRuleCompareType {
  VALUE
  METRIC
  RANKING
  TIME
}

enum CampaignRuleTaskKind {
  START
  PAUSE
  DUPLICATE
  NOTIFY
  INCREASE_BUDGET
  DECREASE_BUDGET
  SET_SPENDING_LIMITS
  REMOVE_SPENDING_LIMITS
  INCREASE_SPENDING_LIMITS
  DECREASE_SPENDING_LIMITS
  ADD_TO_NAME
  REMOVE_FROM_NAME
  REPLACE_TEXT_IN_NAME
  // MB-native (không có trong enum Care Ads):
  BUDGET_SCHEDULE_BUMP // đẩy Meta budget_schedule_specs theo khung giờ, Meta tự revert
  LAUNCH_FROM_TEMPLATE // lên campaign mới từ template MB; entity khớp chỉ là trigger
}

enum CampaignRuleRunStatus {
  RUNNING
  COMPLETED
  FAILED
  SKIPPED_OVERLAP
  SKIPPED_OUT_OF_DATE_RANGE
}

enum CampaignRuleRunItemStatus {
  NOT_MATCHED
  PENDING
  CONFIRMED
  REJECTED
  EXPIRED
  EXECUTED
  FAILED
  SKIPPED
}

model CampaignRule {
  id     String             @id @default(uuid())
  name   String
  status CampaignRuleStatus @default(DRAFT)
  level  CampaignRuleLevel

  // Scope. `accountId` = Account.id (scalar FK, model ngoài cụm này).
  // `campaignId` = Campaign.id — pin rule vào 1 campaign khi mở từ campaign detail;
  // null = phủ cả ad account.
  // `adSetId` = AdSet.id — pin rule vào 1 NHÓM QUẢNG CÁO cụ thể (ABO, mỗi nhóm 1
  // lịch tăng ngân sách riêng); null = cấp campaign (CBO) hoặc phủ account.
  accountId  String
  campaignId String?
  adSetId    String?

  timezone            String // IANA name, hoặc sentinel "account" (resolve theo tz ad account lúc chạy)
  notifyErrorsOnly    Boolean                   @default(false)
  // Email CHỦ ĐỘNG khi rule chạy (opt-in per-rule; người nhận = notifyUsers). Real-time
  // theo SỰ KIỆN, chống gửi trùng qua CampaignRuleRunItem.notifiedAt. "matched" chỉ bắn
  // khi CHUYỂN not-matched→matched (không lặp mỗi lần quét khi điều kiện vẫn đang đúng).
  notifyOnMatch       Boolean                   @default(false) // đủ điều kiện (kể cả PENDING chờ duyệt)
  notifyOnExecute     Boolean                   @default(false) // đã đẩy Meta thành công
  notifyOnError       Boolean                   @default(false) // rule/đẩy Meta lỗi
  filterGroupOperator CampaignRuleGroupOperator @default(OR)
  position            Int                       @default(0)

  useAdSetAttributionWindow Boolean @default(true)
  attributionWindow         String?

  // true = runner tự confirm + đẩy Meta ngay khi khớp (không cần user duyệt tay).
  autoExecute Boolean @default(false)

  // true = bản ghi "gương" phản chiếu budget schedules đang có trên Meta (được các
  // job sync campaign upsert). Mỗi campaign có tối đa 1 bản syncedFromMeta để giữ
  // đồng bộ 1-1 với Meta. Bản do user "Gửi ngay" tạo = false.
  syncedFromMeta Boolean @default(false)

  // Mẫu (CampaignRuleTemplate.id) mà rule này được áp từ — đóng dấu lúc TẠO nếu user bấm
  // "Dùng mẫu". Scalar (không relation, mẫu ngoài cụm scope). Dùng để đếm "mẫu đã áp cho
  // bao nhiêu chiến dịch" → biết mẫu nào hiệu quả để giữ / mẫu nào chưa ai dùng để clear.
  // CHỈ có từ lúc thêm cột trở đi (rule cũ = null, không lấp ngược được).
  sourceTemplateId String?

  schedule     CampaignRuleSchedule?
  filterGroups CampaignRuleFilterGroup[]
  tasks        CampaignRuleTask[]
  runs         CampaignRuleRun[]
  notifyUsers  CampaignRuleNotifyUser[]

  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  // Ai đã xóa (soft delete). Scalar (không relation, User ngoài cụm này — giống
  // createdById). Chỉ để truy vết "ai gỡ lịch", resolve tên lúc hiển thị. rule cũ
  // bị xóa TRƯỚC cột này = null. Cặp với ChangeLog action DELETE_CAMPAIGN_RULE.
  deletedById String?

  @@index([campaignId, status])
  @@index([campaignId, adSetId, status])
  @@index([accountId, updatedAt(sort: Desc)])
  @@index([createdById, updatedAt(sort: Desc)])
  @@index([sourceTemplateId])
  @@map("campaign_rule")
}

// Junction người nhận email của 1 campaign_rule (opt-in per-rule). Scalar FK tới User
// (legacy, ngoài cụm) — chỉ giữ userId, resolve email lúc gửi. Giống AutomationRuleNotifyUser.
model CampaignRuleNotifyUser {
  ruleId String
  userId String

  rule CampaignRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@id([ruleId, userId])
  @@index([userId])
  @@map("campaign_rule_notify_user")
}

// Mẫu quy tắc "lên lịch theo điều kiện" (cuốn chiếu): lưu lại ĐIỀU KIỆN + cấu hình
// tăng ngân sách để áp nhanh cho campaign khác, khỏi nhập lại. KHÔNG gắn scope (tài
// khoản/chiến dịch/nhóm) và KHÔNG kèm lịch quét — chỉ phần tái dùng được.
model CampaignRuleTemplate {
  id          String  @id @default(uuid())
  name        String
  description String?

  // Config tái dùng — ĐÚNG wire shape rule-form dùng: { tasks: [...], filterGroups: [...] }.
  // Áp mẫu = nạp thẳng vào form (giữ nguyên scope + lịch hiện tại của form).
  config Json

  // Chia sẻ: false = riêng người tạo; true = cả team thấy & dùng (thư viện chung).
  isShared Boolean @default(false)

  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@index([createdById, updatedAt(sort: Desc)])
  @@index([isShared, updatedAt(sort: Desc)])
  @@map("campaign_rule_template")
}

model CampaignRuleSchedule {
  id     String       @id @default(uuid())
  ruleId String       @unique
  rule   CampaignRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  type          CampaignRuleScheduleType @default(INTERVAL)
  interval      String? // "15m","30m","60m","3h","6h","12h","24h","36h","72h"
  specificSlots Json? // Record<"sun".."sat", string[]> — slot "HH:MM"
  useDateRange  Boolean                  @default(false)
  dateFrom      DateTime?
  dateTo        DateTime?

  @@map("campaign_rule_schedule")
}

model CampaignRuleFilterGroup {
  id       String                    @id @default(uuid())
  ruleId   String
  rule     CampaignRule              @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  operator CampaignRuleGroupOperator @default(AND)
  position Int                       @default(0)

  filters CampaignRuleFilter[]

  @@index([ruleId, position])
  @@map("campaign_rule_filter_group")
}

model CampaignRuleFilter {
  id            String                  @id @default(uuid())
  filterGroupId String
  filterGroup   CampaignRuleFilterGroup @relation(fields: [filterGroupId], references: [id], onDelete: Cascade)

  field     String
  operator  String
  values    Json
  timeframe String?
  position  Int     @default(0)

  @@index([filterGroupId, position])
  @@map("campaign_rule_filter")
}

model CampaignRuleTask {
  id          String               @id @default(uuid())
  ruleId      String
  rule        CampaignRule         @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  kind        CampaignRuleTaskKind
  subtitle    String?
  description String? // ghi chú UI cho task; runner không dùng
  params      Json?
  position    Int                  @default(0)

  rootGroup CampaignRuleTaskGroup?  @relation("CampaignRuleTaskRoot")
  groups    CampaignRuleTaskGroup[] @relation("CampaignRuleTaskAllGroups")
  runItems  CampaignRuleRunItem[]

  @@index([ruleId, position])
  @@map("campaign_rule_task")
}

model CampaignRuleTaskGroup {
  id     String           @id @default(uuid())
  taskId String
  task   CampaignRuleTask @relation("CampaignRuleTaskAllGroups", fields: [taskId], references: [id], onDelete: Cascade)

  rootForTaskId String?           @unique
  rootForTask   CampaignRuleTask? @relation("CampaignRuleTaskRoot", fields: [rootForTaskId], references: [id], onDelete: Cascade)

  parentGroupId String?
  parentGroup   CampaignRuleTaskGroup?  @relation("CampaignRuleTaskGroupTree", fields: [parentGroupId], references: [id], onDelete: Cascade)
  childGroups   CampaignRuleTaskGroup[] @relation("CampaignRuleTaskGroupTree")

  conditions CampaignRuleTaskCondition[]

  operator CampaignRuleGroupOperator @default(AND)
  position Int                       @default(0)

  @@index([taskId, parentGroupId, position])
  @@map("campaign_rule_task_group")
}

model CampaignRuleTaskCondition {
  id          String                  @id @default(uuid())
  groupId     String
  group       CampaignRuleTaskGroup   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  compareType CampaignRuleCompareType @default(VALUE)
  params      Json
  position    Int                     @default(0)

  @@index([groupId, position])
  @@map("campaign_rule_task_condition")
}

/// Một CampaignRuleRun = 1 lần rule được scheduler fire cho ad account của nó.
model CampaignRuleRun {
  id String @id @default(uuid())

  ruleId String
  rule   CampaignRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  accountId String // scalar FK sang Account

  scheduledFor DateTime
  startedAt    DateTime?
  finishedAt   DateTime?

  // Idempotency: `ruleId:accountId:<aligned scheduledFor ISO>`. NULL cho row skip.
  dedupeKey String?

  status CampaignRuleRunStatus @default(RUNNING)

  entitiesScanned Int @default(0)
  matchedCount    Int @default(0)
  errorsCount     Int @default(0)

  errorMessage String?
  ruleSnapshot Json?

  items CampaignRuleRunItem[]

  createdAt DateTime @default(now())

  @@unique([dedupeKey])
  @@index([ruleId, scheduledFor(sort: Desc)])
  @@index([accountId, scheduledFor(sort: Desc)])
  @@index([status, scheduledFor(sort: Desc)])
  @@map("campaign_rule_run")
}

/// Mỗi entity match 1 task = 1 row; giữ snapshot + change preview cho UI log-detail.
model CampaignRuleRunItem {
  id String @id @default(uuid())

  runId String
  run   CampaignRuleRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  taskId   String?
  task     CampaignRuleTask?     @relation(fields: [taskId], references: [id], onDelete: SetNull)
  taskKind CampaignRuleTaskKind?

  level       CampaignRuleLevel
  entityId    String // Campaign.id / AdSet.id / Ad.id
  entityName  String
  parentLabel String?

  status CampaignRuleRunItemStatus @default(PENDING)

  snapshot      Json
  changePreview Json
  evaluation    Json?

  matchedConditionSummary String?

  confirmedAt   DateTime?
  confirmedById String? // scalar FK sang User
  executedAt    DateTime?
  errorMessage  String?

  executionAttempts Int     @default(0)
  executionError    Json?
  metaTraceId       String?

  asyncRequestIds   String?
  asyncPollAttempts Int     @default(0)

  // Id các HighDemandPeriod (budget_schedule) Meta trả về khi đẩy thành công —
  // lưu để sau này TẮT/XOÁ lịch trên Meta (new HighDemandPeriod(id).delete()).
  metaBudgetScheduleIds String[] @default([])

  // Đã gửi email thông báo cho item này chưa — chống gửi trùng (1 mail / sự kiện).
  // null = chưa gửi / không thuộc diện notify. Set khi cron mb-ads gửi mail xong.
  notifiedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([runId])
  @@index([entityId])
  @@index([taskId])
  @@index([status, createdAt(sort: Desc)])
  @@map("campaign_rule_run_item")
}

// ============================================================================
// AUTO-LAUNCH RULE — "Quy tắc tự lên Camp"
// ----------------------------------------------------------------------------
// Marketer hay tìm creative ROAS/chỉ số ngon rồi nhân lên bằng MẪU có sẵn. Cụm này
// canh giúp: gom đủ N creative ĐẠT CHUẨN (organic valid-post, KHÔNG dark post) → tự
// lên 1 chiến dịch từ mẫu (điền mỗi creative vào 1 vị trí) → hoặc để BẢN NHÁP cho
// người duyệt, hoặc TỰ ĐĂNG lên Meta.
//
// Điều kiện + lịch dùng CHUNG bộ rule-builder với "lịch tăng ngân sách" (Care Ads) →
// lưu theo shape `config = { tasks: [...] }` (cây điều kiện, giống CampaignRuleTemplate)
// + `schedule` JSON. Runner mb-batch rút VALUE conditions ra chấm từng creative trên
// CreativeInsight; hành động lên camp bọc pipeline "Lên Camp bằng template" hiện có.
//
// CHỐNG SPAM (nhiều lớp): lịch theo KHUNG GIỜ (SPECIFIC) thay vì loop; mỗi lần kiểm
// tra tối đa 1 camp; trần camp/ngày; creative đã dùng KHÔNG chọn lại (reuse NEW_ONLY).
//
// Additive/non-breaking. Migration TAY (chưa `prisma migrate dev` vs prod) — xem
// prisma/migrations/<ts>_auto_launch_rule/migration.sql.
// ============================================================================

enum AutoLaunchRuleStatus {
  ACTIVE
  PAUSED
}

enum AutoLaunchRunStatus {
  LAUNCHED // đã lên 1 chiến dịch (nháp hoặc tự đăng)
  SKIPPED_NOT_ENOUGH // chưa gom đủ N creative đạt chuẩn
  SKIPPED_DAILY_CAP // đã chạm trần camp/ngày
  SKIPPED_NO_NEW // đủ chỉ số nhưng hết creative MỚI (đã dùng hết)
  FAILED // lỗi khi dựng/đăng (cũng dùng làm trạng thái CLAIM tạm: insert-first mang dedupeKey rồi update thành trạng thái cuối)
}

model AutoLaunchRule {
  id     String               @id @default(uuid())
  name   String
  status AutoLaunchRuleStatus @default(ACTIVE)

  // Các Account.id để QUÉT creative (và lên camp cho CHÍNH tài khoản đó — post_id
  // reuse cùng account, an toàn). Mỗi tài khoản gom đủ N → 1 camp trên nó.
  accountIds String[]

  // Cây điều kiện rule-builder: { tasks: [{ rootGroup, ... }] } — CHUNG shape với
  // CampaignRuleTemplate.config. Runner rút các VALUE condition (metric/operator/amount
  // + timeframe) ra để chấm mỗi creative.
  config Json

  // Lịch chạy — { type:"INTERVAL"|"SPECIFIC", interval?, specificSlots?, useDateRange?,
  // dateFrom?, dateTo? } (đúng RHF `schedule.*` của rule-builder). Mặc định SPECIFIC
  // theo khung giờ để chống spam.
  schedule Json

  // Mẫu để lên (TemplateCampaign.id, scalar FK). minQualifying = gom đủ N → 1 camp.
  templateId    String
  minQualifying Int    @default(5)

  // Xong thì làm gì — tái dùng enum của draft-automation (DRAFT_ONLY | PUBLISH_IMMEDIATELY).
  publishMode DraftAutomationPublishMode @default(DRAFT_ONLY)

  // CHỐNG SPAM: trần chiến dịch/ngày (áp cả nháp lẫn tự đăng).
  maxCampaignsPerDay   Int  @default(2)
  // Chỉ khi tự đăng: trần ngân sách mỗi chiến dịch (VND, major units).
  budgetCapPerCampaign Int?

  // Số chiến dịch quy tắc này đã tạo ra (đếm cộng dồn — hiển thị + đối soát).
  launchedCount Int @default(0)

  runs AutoLaunchRuleRun[]

  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@index([status, updatedAt(sort: Desc)])
  @@index([createdById, updatedAt(sort: Desc)])
  @@map("auto_launch_rule")
}

// Nhật ký chạy (như Care Ads AutomationRuleRun) — mỗi lần runner kiểm tra 1 khung giờ
// ghi 1 bản ghi: đã lên camp / chưa đủ / chạm trần / hết creative mới / lỗi.
model AutoLaunchRuleRun {
  id     String         @id @default(uuid())
  ruleId String
  rule   AutoLaunchRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  scheduledFor DateTime // mốc khung giờ đã canh (aligned) — cùng dùng cho dedupe
  status       AutoLaunchRunStatus
  scanned      Int                 @default(0) // số creative quét qua
  qualified    Int                 @default(0) // số đạt chuẩn (đã loại dark + đã dùng)
  message      String? // diễn giải ngắn cho marketer

  // Khi LAUNCHED:
  usedCreatives       Json? // [{ id, name, roas, campaignId }] — creative đưa vào camp + camp nào (ledger per-campaign + đếm trần theo distinct campaignId, KHÔNG cần migration)
  generatedCampaignId String? // SystemCampaign.id sinh ra (camp ĐẦU — tương thích ngược)
  metaId              String? // meta campaign id (nếu đã tự đăng)
  mode                DraftAutomationPublishMode?

  // Idempotency chống chạy trùng cùng 1 khung: "ruleId:<aligned scheduledFor ISO>".
  dedupeKey String? @unique

  createdAt DateTime @default(now())

  @@index([ruleId, createdAt(sort: Desc)])
  @@map("auto_launch_rule_run")
}
