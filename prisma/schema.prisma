// ==========================================================================
// AUTOMATION (Birch-style rule engine)
// Added in migration `add_automation`. Không chạm vào models legacy ở trên.
// ==========================================================================

enum AutomationRuleLevel {
  AD_ACCOUNT
  CAMPAIGN
  ADSET
  AD
}

enum AutomationScheduleType {
  INTERVAL
  SPECIFIC
}

enum AutomationTaskKind {
  START
  PAUSE
  DUPLICATE
  NOTIFY
  INCREASE_BUDGET
  DECREASE_BUDGET
  SET_SPENDING_LIMITS
  REMOVE_SPENDING_LIMITS
  INCREASE_SPENDING_LIMITS
  DECREASE_SPENDING_LIMITS
  ADD_TO_NAME
  REMOVE_FROM_NAME
  REPLACE_TEXT_IN_NAME
}

enum AutomationGroupOperator {
  AND
  OR
}

enum AutomationCompareType {
  VALUE
  METRIC
  RANKING
  TIME
}

model AutomationCategory {
  id       String @id @default(uuid())
  name     String
  position Int    @default(0)

  folders          AutomationFolder[]
  rules            AutomationRule[]
  customMetrics    CustomMetric[]
  customTimeframes AutomationCustomTimeframe[]

  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@index([createdById, position])
}

model AutomationFolder {
  id       String @id @default(uuid())
  name     String
  position Int    @default(0)

  categoryId String
  category   AutomationCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  parentId String?
  parent   AutomationFolder?  @relation("AutomationFolderTree", fields: [parentId], references: [id], onDelete: Cascade)
  children AutomationFolder[] @relation("AutomationFolderTree")

  rules AutomationRule[]

  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@index([categoryId, parentId, position])
  @@index([parentId])
}

model AutomationRule {
  id                  String                  @id @default(uuid())
  name                String
  status              AutomationRuleStatus    @default(DRAFT)
  level               AutomationRuleLevel
  timezone            String
  notifyErrorsOnly    Boolean                 @default(false)
  filterGroupOperator AutomationGroupOperator @default(OR)
  position            Int                     @default(0)

  useAdSetAttributionWindow Boolean @default(true)
  attributionWindow         String?

  // When true, matched items are auto-confirmed by the runner and pushed to the
  // executor in the same tick — no manual confirm step. Default false preserves
  // the manual-confirm behaviour for every existing rule.
  autoExecute Boolean @default(false)

  categoryId String
  category   AutomationCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  folderId String?
  folder   AutomationFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)

  schedule     AutomationSchedule?
  filterGroups AutomationFilterGroup[]
  tasks        AutomationTask[]
  adAccounts   AutomationRuleAdAccount[]
  notifyUsers  AutomationRuleNotifyUser[]
  runs         AutomationRuleRun[]

  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@index([categoryId, folderId, position])
  @@index([createdById, updatedAt(sort: Desc)])
  @@index([status, updatedAt(sort: Desc)])
}

enum AutomationRuleStatus {
  DRAFT
  ACTIVE
  PAUSED
}

// Junction tới legacy Account: scalar FK only (không @relation sang Account để không
// phải thêm back-relation vào model Account cũ).
model AutomationRuleAdAccount {
  ruleId    String
  accountId String

  rule AutomationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@id([ruleId, accountId])
  @@index([accountId])
}

/// User-defined custom timeframe (Days range 0..90, hoặc Hours range 0..24).
/// Lưu offsets thay vì absolute timestamps — runner resolve relative tới `now`
/// theo ad account timezone qua `resolveCustomTimeframeWindow`.
/// Rule reference qua chuỗi `"custom:<id>"` trong AutomationTaskCondition.params.timeframe.
/// Scope theo `AutomationCategory` — mọi rule trong category đó share & edit
/// được. Cascade delete khi xoá category.
model AutomationCustomTimeframe {
  id          String             @id @default(uuid())
  name        String
  kind        String // "days" | "hours" — validate ở zod
  fromOffset  Int // L position; 0 = today/current hour
  toOffset    Int // R position; fromOffset <= toOffset; max 90 (days) hoặc 24 (hours)
  categoryId  String
  category    AutomationCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdById String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([categoryId])
}

enum CustomMetricScope {
  GLOBAL
  AD_ACCOUNT
  CATEGORY
}

enum CustomMetricFormat {
  numeric
  currency
  percentage
}

/// User-defined custom metric: a formula combining native Meta metrics + numbers
/// + arithmetic operators (vd ROAS = action_values / spend). `formula` lưu token
/// array JSON (mirror Bir.ch): [{ type, value, key }] với type ∈ variable|number|operator.
/// Rule reference qua chuỗi `"custom_metric:<id>"` trong AutomationTaskCondition.params.metric.
/// Scope GLOBAL → accountId/categoryId null (mọi user thấy);
/// AD_ACCOUNT → accountId bắt buộc; CATEGORY → categoryId bắt buộc (toàn rule trong category đó thấy).
/// `accountId`/`createdById` là scalar FK (không @relation back-ref, theo pattern AutomationCustomTimeframe).
model CustomMetric {
  id          String              @id @default(uuid())
  name        String // min(1) max(50)
  description String? // max(200)
  format      CustomMetricFormat  @default(numeric)
  scope       CustomMetricScope
  formula     Json // FormulaToken[]
  accountId   String? // bắt buộc khi scope=AD_ACCOUNT, null khi khác
  categoryId  String? // bắt buộc khi scope=CATEGORY, null khi khác
  category    AutomationCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdById String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([accountId])
  @@index([categoryId])
  @@index([scope])
  @@map("custom_metrics")
}

// Junction tới legacy User: scalar FK only.
model AutomationRuleNotifyUser {
  ruleId String
  userId String

  rule AutomationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@id([ruleId, userId])
  @@index([userId])
}

model AutomationSchedule {
  id     String         @id @default(uuid())
  ruleId String         @unique
  rule   AutomationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  type          AutomationScheduleType @default(INTERVAL)
  interval      String?
  specificSlots Json?
  useDateRange  Boolean                @default(false)
  dateFrom      DateTime?
  dateTo        DateTime?
}

model AutomationFilterGroup {
  id       String                  @id @default(uuid())
  ruleId   String
  rule     AutomationRule          @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  operator AutomationGroupOperator @default(AND)
  position Int                     @default(0)

  filters AutomationFilter[]

  @@index([ruleId, position])
}

model AutomationFilter {
  id            String                @id @default(uuid())
  filterGroupId String
  filterGroup   AutomationFilterGroup @relation(fields: [filterGroupId], references: [id], onDelete: Cascade)

  field     String
  operator  String
  values    Json
  timeframe String?
  position  Int     @default(0)

  @@index([filterGroupId, position])
}

model AutomationTask {
  id          String             @id @default(uuid())
  ruleId      String
  rule        AutomationRule     @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  kind        AutomationTaskKind
  subtitle    String?
  description String? // UI-only annotation per task (Bir.ch parity); not used by the runner
  params      Json?
  position    Int                @default(0)

  rootGroup AutomationTaskGroup?    @relation("AutomationTaskRoot")
  groups    AutomationTaskGroup[]   @relation("AutomationTaskAllGroups")
  runItems  AutomationRuleRunItem[]

  @@index([ruleId, position])
}

model AutomationTaskGroup {
  id     String         @id @default(uuid())
  taskId String
  task   AutomationTask @relation("AutomationTaskAllGroups", fields: [taskId], references: [id], onDelete: Cascade)

  rootForTaskId String?         @unique
  rootForTask   AutomationTask? @relation("AutomationTaskRoot", fields: [rootForTaskId], references: [id], onDelete: Cascade)

  parentGroupId String?
  parentGroup   AutomationTaskGroup?  @relation("AutomationGroupTree", fields: [parentGroupId], references: [id], onDelete: Cascade)
  childGroups   AutomationTaskGroup[] @relation("AutomationGroupTree")

  conditions AutomationTaskCondition[]

  operator AutomationGroupOperator @default(AND)
  position Int                     @default(0)

  @@index([taskId, parentGroupId, position])
}

model AutomationTaskCondition {
  id          String                @id @default(uuid())
  groupId     String
  group       AutomationTaskGroup   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  compareType AutomationCompareType @default(VALUE)
  params      Json
  position    Int                   @default(0)

  @@index([groupId, position])
}

// ==========================================================================
// AUTOMATION RUNNER LOG (Bir.ch-style scan & log)
// ==========================================================================

enum AutomationRuleRunStatus {
  RUNNING
  COMPLETED
  FAILED
  SKIPPED_OVERLAP
  SKIPPED_OUT_OF_DATE_RANGE
}

enum AutomationRuleRunItemStatus {
  NOT_MATCHED // entity passed filter group but no task condition matched
  PENDING
  CONFIRMED
  REJECTED
  EXPIRED
  EXECUTED
  FAILED
  SKIPPED // handler decided no API call needed (cap reached, frequency limit, CBO/ABO mismatch, …)
}

/// Một AutomationRuleRun = 1 lần (rule × ad account) được scheduler fire.
model AutomationRuleRun {
  id String @id @default(uuid())

  ruleId String
  rule   AutomationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  // Scalar FK only sang Account (model ngoài block automation)
  accountId String

  scheduledFor DateTime
  startedAt    DateTime?
  finishedAt   DateTime?

  // Idempotency guard: `ruleId:accountId:<aligned scheduledFor ISO>`, set only on
  // real runs (not SKIPPED_OVERLAP). NULL on legacy/skip rows — Postgres treats
  // NULLs as distinct, so the unique index only enforces one real run per window.
  dedupeKey String?

  status AutomationRuleRunStatus @default(RUNNING)

  entitiesScanned Int @default(0)
  matchedCount    Int @default(0)
  errorsCount     Int @default(0)

  errorMessage String?
  ruleSnapshot Json?

  items AutomationRuleRunItem[]

  createdAt DateTime @default(now())

  @@unique([dedupeKey])
  @@index([ruleId, scheduledFor(sort: Desc)])
  @@index([accountId, scheduledFor(sort: Desc)])
  @@index([status, scheduledFor(sort: Desc)])
}

/// Mỗi entity match 1 task = 1 row, lưu snapshot + change preview cho UI log-detail.
model AutomationRuleRunItem {
  id String @id @default(uuid())

  runId String
  run   AutomationRuleRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  // Nullable for NOT_MATCHED rows (entity passed filter but no task condition matched)
  taskId   String?
  task     AutomationTask?     @relation(fields: [taskId], references: [id], onDelete: SetNull)
  taskKind AutomationTaskKind?

  level       AutomationRuleLevel
  // Scalar — entityId là Campaign.id / AdSet.id / Ad.id (3 bảng ngoài block automation)
  entityId    String
  entityName  String
  parentLabel String?

  status AutomationRuleRunItemStatus @default(PENDING)

  snapshot      Json
  changePreview Json
  evaluation    Json?

  matchedConditionSummary String?

  // Scalar FK only sang User (model ngoài block automation)
  confirmedAt   DateTime?
  confirmedById String?
  executedAt    DateTime?
  errorMessage  String?

  /// Number of times the Meta executor has attempted this item — increments on
  /// every retry. Used by the processor for backoff and for FE diagnostics.
  executionAttempts Int @default(0)

  /// Structured Meta API error captured on the most recent attempt (code,
  /// subcode, fbtrace, user/developer messages). Null while item is healthy.
  executionError Json?

  /// `fbtrace_id` from the Meta response; surfaced in FE tooltips so support
  /// can correlate with Meta's own logs.
  metaTraceId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([runId])
  @@index([entityId])
  @@index([taskId])
  @@index([status, createdAt(sort: Desc)])
}

// ==========================================================================
// AUTOMATION INSIGHT CACHE
// Persistent historical insight cache để giảm tải Meta API.
// Granularity = apiLevel (adset|ad); rollup lên campaign chạy ở read-time.
// Scalar accountId (không @relation sang Account legacy). Migration:
// `add_automation_insight_cache` (raw SQL — KHÔNG dùng `prisma migrate dev`).
// ==========================================================================

enum AutomationInsightApiLevel {
  ADSET
  AD
}

enum AutomationInsightBackfillStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

/// Daily settled insight bucket (1 dòng/entity/ngày). Chỉ lưu ngày đã "đóng
/// băng" (date < boundary B = today − freezeDays). `metrics` (Json) giữ raw
/// additive inputs cần cho merge (spend/impressions/clicks/inline_link_clicks/
/// outbound_clicks/results + actions[]/action_values[]/video_*_watched_actions).
/// KHÔNG lưu ratio (recompute từ input) và KHÔNG lưu reach/frequency (dedup
/// theo cửa sổ → cộng ngày sẽ sai). Một ngày fetch DUY NHẤT 1 lần (immutable).
model AutomationInsightDaily {
  id        String                    @id @default(uuid())
  accountId String
  apiLevel  AutomationInsightApiLevel
  entityId  String
  date      String // YYYY-MM-DD (date_start == date_stop)
  metrics   Json
  createdAt DateTime                  @default(now())

  @@unique([accountId, apiLevel, entityId, date])
  @@index([accountId, apiLevel, date])
}

/// Tiến độ/observability của backfill per (account, apiLevel). KHÔNG phải nguồn
/// sự thật về coverage — nguồn sự thật là các ngày thực có trong
/// AutomationInsightDaily. Job gap-driven tự reconcile required vs present.
model AutomationInsightBackfillState {
  id                String                          @id @default(uuid())
  accountId         String
  apiLevel          AutomationInsightApiLevel
  status            AutomationInsightBackfillStatus @default(PENDING)
  targetSinceDate   String
  oldestSettledDate String?
  lastSettledDate   String?
  lastRevalidatedAt DateTime?
  /// Last time an ACTIVE rule (run or warmer) confirmed this (account, apiLevel)
  /// is still in use. The maintain scheduler skips states whose lastEvaluatedAt
  /// is null or older than AUTOMATION_INSIGHT_STALE_DAYS so deleted/paused rules
  /// stop being backfilled forever.
  lastEvaluatedAt   DateTime?
  errorMessage      String?
  updatedAt         DateTime                        @updatedAt

  @@unique([accountId, apiLevel])
}

/// (PHASE 2) Aggregate đóng băng cho quá khứ sâu của timeframe `maximum`
/// (lifetime): gộp các ngày [creation .. throughDate] vào 1 dòng để khỏi lưu
/// daily cho toàn bộ lifetime. `maximum` = deepAggregate + Σ daily + live.
model AutomationInsightDeepAggregate {
  id          String                    @id @default(uuid())
  accountId   String
  apiLevel    AutomationInsightApiLevel
  entityId    String
  throughDate String
  metrics     Json
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt

  @@unique([accountId, apiLevel, entityId])
}

/// Latest Meta rate-limit usage observed from response headers, persisted per
/// (scope, bucket) so the per-account limit/throttle state is queryable (the
/// Redis snapshot only lives ~1h and can't be listed). `scope` = Meta account id
/// or the sentinel `__app__`; `bucket` = ads_management | ads_insights | app.
/// `maxPct` = worst of call_count/cputime/total_time (0-100); `regainSec` =
/// estimated_time_to_regain_access. Upserted (latest wins), throttled ~1/min.
model AutomationMetaUsage {
  id         String   @id @default(uuid())
  scope      String
  bucket     String
  maxPct     Float    @default(0)
  regainSec  Int      @default(0)
  tier       String?
  observedAt DateTime
  updatedAt  DateTime @updatedAt

  @@unique([scope, bucket])
  @@index([scope])
}

enum MetaConnectionStatus {
  ACTIVE
  REVOKED
  INVALID
}

model MetaConnection {
  id String @id @default(uuid())

  /// Scalar FK to User (User lives outside the automation block, keep relation lightweight).
  userId String @unique

  /// AES-256-GCM ciphertext envelope of the long-lived Meta access token.
  encryptedAccessToken String

  /// "SYSTEM_USER" for MVP; "USER" reserved for future OAuth flow.
  tokenType String @default("SYSTEM_USER")

  fbUserId     String?
  fbBusinessId String?
  scopes       String[] @default([])

  status         MetaConnectionStatus @default(ACTIVE)
  lastVerifiedAt DateTime?

  accounts Account[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}
