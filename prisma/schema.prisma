generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// =======================
// ENUMS
// =======================
enum Role {
  ADMIN
  EMPLOYEE
}

enum AccountType {
  AD_ACCOUNT
  PAGE
  INSTAGRAM
  BUSINESS_MANAGER
}

enum MemberRole {
  OWNER
  MANAGER
  EDITOR
  VIEWER
}

enum FanpagePermission {
  VIEW
  EDIT
  ADMIN
}

enum ProductCatalogPermission {
  VIEW
  EDIT
  ADMIN
}

/// ===============================
/// ENUMS
/// ===============================

enum Status {
  DRAFT
  ACTIVE
  PAUSED
  DELETED
  ARCHIVED
}

enum InsightRange {
  MAX
  DAY_7
  DAY_3
  TODAY
  DAILY
}

/// Trạng thái sức khỏe nội dung quảng cáo do bộ phát hiện Ad Fatigue tính toán.
/// Không tự động thay đổi trạng thái phân phối của Ad.
enum AdFatigueStatus {
  INSUFFICIENT_DATA
  HEALTHY
  WATCH
  FATIGUED
}

enum LevelInsight {
  AD
  CAMPAIGN
  ADSET
}

// =======================
// MODELS
// =======================
model TargetingInterest {
  // Khoá cache. Với locale mặc định (en_US) `id` CHÍNH LÀ Meta id — giữ nguyên
  // ngữ nghĩa cũ để không phá dữ liệu/đường đọc hiện có. Với locale khác, `id`
  // là khoá tổng hợp "<metaId>__<locale>" để 2 bản dịch của cùng 1 interest
  // không ghi đè lẫn nhau. LUÔN dùng `metaId` khi cần id thật gửi cho Meta.
  id                        String  @id @default(uuid())
  // Loại targeting: interests | behaviors | demographics | life_events | locales.
  // Dữ liệu cũ mặc định là "interests"; giá trị mới được search lưu đúng loại.
  type                      String  @default("interests")
  // Locale của BẢN GHI (tên/mô tả theo ngôn ngữ nào). Hàng cũ = en_US.
  locale                    String  @default("en_US")
  // Id thật bên Meta (locales dùng `key`). Hàng cũ được backfill = id.
  metaId                    String?
  name                      String
  description               String?
  audience_size_lower_bound Int?
  audience_size_upper_bound Int?
  path                      Json?
  topic                     String?

  @@unique([metaId, locale])
  @@index([type])
  @@index([type, locale])
}

model DropdownCategory {
  id          String  @id @default(uuid())
  key         String  @unique
  name        String
  description String?

  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  createdById String?
  updatedAt   DateTime  @updatedAt
  updatedById String?
  deletedAt   DateTime?

  items DropdownItem[] @relation("DropdownCategory_Items")

  @@index([key])
}

model DropdownItem {
  id          String    @id @default(uuid())
  categoryId  String
  externalId  String? // ví dụ: "LINK_CLICKS"
  name        String
  value       String?
  description String?
  color       String?
  sortOrder   Int       @default(0)
  metadata    Json?
  isDefault   Boolean   @default(false)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  createdById String?
  updatedAt   DateTime  @updatedAt
  updatedById String?
  deletedAt   DateTime?

  category DropdownCategory @relation("DropdownCategory_Items", fields: [categoryId], references: [id])

  @@unique([categoryId, value])
  @@index([categoryId])
  @@index([externalId])
}

model User {
  id            String  @id @default(uuid())
  email         String  @unique
  employee_id   String?
  name          String
  password      String
  role          Role    @default(EMPLOYEE)
  facebookToken String?

  parentId String?
  parent   User?   @relation("UserChildren", fields: [parentId], references: [id])
  children User[]  @relation("UserChildren")

  locale String?

  // ── Lark / danh bạ (đồng bộ từ Lark Contact API theo email) ──────────────
  // Tất cả nullable + additive: user tạo tay/không có trên Lark vẫn hợp lệ.
  // `employee_id` (ở trên) = Lark `employee_no` (mã số nhân viên).
  avatar            String? // URL avatar (Lark avatar_240) — hiển thị ở list/detail
  // open_id — ID gửi tin nhắn/notify & đẩy Larkbase. KHÔNG unique: một người Lark
  // có thể gắn NHIỀU tài khoản MB (vd cùng người dùng 2 email công ty
  // @tvhs.asia và @thanhvinhgroup.com = 2 tài khoản RIÊNG, cùng trỏ 1 open_id).
  larkOpenId        String?
  larkUserId        String? // user_id nội bộ tenant Lark
  larkUnionId       String? // union_id ổn định cross-app
  larkMobile        String? // số điện thoại từ danh bạ
  larkJobTitle      String? // chức danh
  larkDepartmentIds Json? // string[] open_department_id
  larkRaw           Json? // payload get-user đầy đủ (dự phòng, không đóng đinh cột)
  larkSyncedAt      DateTime? // lần cuối đồng bộ thành công từ Lark

  // relations
  changeLogs     ChangeLog[]          @relation("change_actor")
  accountMembers AccountMember[]      @relation("UserAccountMembers")
  userFanpages   UserFanpage[]
  userCatalogs   UserProductCatalog[]
  projectMembers ProjectMember[]
  folderMembers  FolderMember[]
  savedFilters   SavedFilter[]
  exportPresets  ExportPreset[]
  metricPresets  MetricPreset[]

  messageTemplates MessageTemplate[] @relation("UserMessageTemplates")

  createdAt   DateTime  @default(now())
  createdById String?
  updatedAt   DateTime  @updatedAt
  updatedById String?
  deletedAt   DateTime?
  deletedById String?

  activities             UserActivity[]
  contributions          Contribution[]    @relation("UserContributions")
  processedContributions Contribution[]    @relation("ProcessedContributions")
  proposals              AccountProposal[] @relation("UserProposals")
  processedProposals     AccountProposal[] @relation("ProcessedProposals")
  helpChatSessions       HelpChatSession[] @relation("UserHelpChatSessions")

  assetAccessRequests    AssetAccessRequest[] @relation("AssetReqRequester")
  assignedAssetRequests  AssetAccessRequest[] @relation("AssetReqAssignee")
  processedAssetRequests AssetAccessRequest[] @relation("AssetReqProcessor")

  @@index([larkOpenId]) // tra nhanh mọi tài khoản MB của 1 người Lark (notify/Larkbase)
}

model UserActivity {
  id          String   @id @default(uuid())
  userId      String? // Có thể null nếu API gọi khi chưa đăng nhập
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  method      String // VD: GET, POST, PUT, DELETE
  path        String // API endpoint (VD: /api/campaigns)
  actionLabel String? // Human readable action
  ipAddress   String? // Địa chỉ IP
  userAgent   String? // Browser/Device
  duration    Int? // Thời gian phản hồi API (để đo performance)
  statusCode  Int? // Trạng thái HTTP (200, 400, 500)
  createdAt   DateTime @default(now())

  // Tối ưu tốc độ query khi bạn thống kê tần suất
  @@index([userId])
  @@index([createdAt])
  @@index([path, method])
}

model UserFanpage {
  id     String  @id @default(uuid())
  userId String
  user   User    @relation(fields: [userId], references: [id])
  pageId String // ID của Fanpage (ví dụ từ Meta)
  page   Fanpage @relation(fields: [pageId], references: [id])

  name       String? // Tên hiển thị trong dropdown
  permission FanpagePermission @default(VIEW)
  isActive   Boolean           @default(true)
  createdAt  DateTime          @default(now())

  @@index([userId, pageId])
}

model UserProductCatalog {
  id        String         @id @default(uuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id])
  catalogId String
  catalog   ProductCatalog @relation(fields: [catalogId], references: [id])

  permission ProductCatalogPermission @default(VIEW)
  isActive   Boolean                  @default(true)
  createdAt  DateTime                 @default(now())

  @@index([userId, catalogId])
}

// [{"id": "249650921563125", "name": "Seyoul Beauty - Malaysia"}, {"id": "111534788320800", "name": "Seyoul Smooth Skin - ผิวเรียบเนียนไร้กาลเวลา"}]
model Fanpage {
  id                     String            @id
  name                   String?
  rawPayload             Json?
  messageTemplates       Json?
  userFanpages           UserFanpage[]
  projectFanpages        ProjectFanpage[]
  creatives              Creative[]
  messageTemplateLibrary MessageTemplate[] @relation("FanpageMessageTemplates")
}

/// Kênh của template tin nhắn lưu nội bộ (không submit Meta).
enum MessageTemplateChannel {
  MESSENGER
  WHATSAPP
}

/// Thư viện template tin nhắn lưu trong hệ thống, gắn theo Fanpage.
/// Dùng cho màn quản lý template "Conversations" (Messenger) và WhatsApp.
model MessageTemplate {
  id      String                 @id @default(uuid())
  name    String
  channel MessageTemplateChannel

  fanpageId String
  fanpage   Fanpage @relation("FanpageMessageTemplates", fields: [fanpageId], references: [id], onDelete: Cascade)

  /// Người tạo — chỉ người này (hoặc ADMIN) mới được sửa/xoá; người khác chỉ dùng/sao chép.
  /// null = bản seed hệ thống (chỉ ADMIN sửa được).
  createdById String?
  createdBy   User?   @relation("UserMessageTemplates", fields: [createdById], references: [id], onDelete: SetNull)

  /// Payload thống nhất theo channel:
  /// - MESSENGER: { greeting, mediaType, mediaUrl, actionType, actions[] }
  /// - WHATSAPP : { id, name, status, category, language, components[] } (WaTemplateRaw)
  spec Json

  /// Nguồn gốc + khử trùng khi seed
  source     String? // 'manual' | 'clone' | 'seed:creative' | 'seed:fanpage'
  sourceHash String? // hash ổn định của spec đã chuẩn hoá, để dedupe khi seed

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([fanpageId, channel, sourceHash])
  @@index([fanpageId, channel])
  @@index([createdById])
}

model Account {
  // store as string to support "act_123", "page_123", "business_123"
  id            String      @id
  accountType   AccountType
  name          String?
  currency      String?
  timezone      String?
  /// Mã quốc gia ISO-3166 của TKQC (Meta `business_country_code`) = THỊ TRƯỜNG tài
  /// khoản đang chạy. Dùng để search targeting theo đúng thị trường (locale) và cho
  /// reach estimate theo quốc gia. KHÔNG suy từ `currency` — rất nhiều TKQC chạy
  /// Đông Nam Á nhưng để USD. Null = chưa sync lại kể từ khi thêm cột; khi null thì
  /// app suy tạm từ `timezone` (xem meta-locale.util).
  countryCode   String?
  businessId    String?
  businessName  String?
  needsReauth   Boolean     @default(false)
  lastFetchedAt DateTime?
  rawPayload    Json?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  pages           Json?
  pixels          Json?
  customAudiences Json?

  /// Danh sách Fanpage mà CHÍNH TKQC này được phép quảng bá (Meta edge
  /// `act_<id>?fields=promote_pages{id,name}`). KHÁC với `pages` (là danh sách
  /// Trang user quản lý, giống nhau ở mọi account) — `promotePages` là quyền THẬT
  /// per-TKQC. Dùng để gate scale/re-use dark post cross-account: chỉ cho dùng
  /// `object_story_id = {pageId}_...` khi pageId nằm trong promotePages của TKQC
  /// đích (tránh Meta 1815017). Shape: [{ id, name }]. Do entity-sync (mb-batch)
  /// + các nút Sync/onboard (mb-ads) ghi vào; null = chưa sync lần nào.
  promotePages Json?

  /// FK to the MetaConnection whose access token authorises Meta Graph calls
  /// targeting this ad account. Nullable while a connection has not yet been
  /// bound — the executor refuses to push changes for accounts without one.
  metaConnectionId String?
  metaConnection   MetaConnection? @relation(fields: [metaConnectionId], references: [id], onDelete: SetNull)

  // relations
  members         AccountMember[]  @relation("AccountAccountMembers")
  projectAccounts ProjectAccount[]
  campaigns       Campaign[]
  adSets          AdSet[]
  ads             Ad[]
  creatives       Creative[]
  adImages        AdImage[]
  adVideos        AdVideo[]
  cidGroups       CidGroup[]
  systemCampaigns SystemCampaign[]
  systemAdSets    SystemAdSet[]
  systemAds       SystemAd[]
  systemCreatives SystemCreative[]

  @@index([accountType])
  @@index([needsReauth])
  @@index([metaConnectionId])
}

model AccountMember {
  id        String @id @default(uuid())
  accountId String
  userId    String

  account Account @relation("AccountAccountMembers", fields: [accountId], references: [id], onDelete: Cascade)
  user    User    @relation("UserAccountMembers", fields: [userId], references: [id])

  role      MemberRole
  createdAt DateTime   @default(now())

  // one membership per user per account
  @@unique([accountId, userId])
  @@index([accountId])
  @@index([userId])
}

model Campaign {
  id        String  @id // store facebook id as string, e.g. "238393..."
  accountId String
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  systemCampaignId String?
  systemCampaign   SystemCampaign? @relation(fields: [systemCampaignId], references: [id], onDelete: Cascade)

  name             String?
  status           String?
  effectiveStatus  String?
  configuredStatus String?
  objective        String?
  buyingType       String?
  effectiveBudget  Int       @default(0)
  dailyBudget      Int?
  lifetimeBudget   Int?
  startTime        DateTime?
  endTime          DateTime?
  remoteUpdatedAt  DateTime?
  lastFetchedAt    DateTime?
  rawPayload       Json?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now())
  deletedAt DateTime?

  insight3dId String?          @unique
  insight3d   CampaignInsight? @relation("Campaign_3D", fields: [insight3dId], references: [id])

  insight7dId String?          @unique
  insight7d   CampaignInsight? @relation("Campaign_7D", fields: [insight7dId], references: [id])

  insightMaxId String?          @unique
  insightMax   CampaignInsight? @relation("Campaign_MAX", fields: [insightMaxId], references: [id])

  insightTodayId String?          @unique
  insightToday   CampaignInsight? @relation("Campaign_TODAY", fields: [insightTodayId], references: [id])

  adsets                   AdSet[]
  ads                      Ad[]
  campaignInsights         CampaignInsight[]
  adSetInsights            AdSetInsight[]
  creativeInsights         CreativeInsight[]
  campaignAudienceInsights CampaignAudienceInsight[]

  // INSIGHT DATA
  impressions Int?   @default(0)
  reach       Int?   @default(0)
  frequency   Float? @default(0)

  /**
   * ===== TRAFFIC =====
   */
  clicks       Int?   @default(0)
  uniqueClicks Int?   @default(0)
  ctr          Float? @default(0)
  uniqueCtr    Float? @default(0)
  cpc          Float? @default(0)
  cpm          Float? @default(0)

  /**
   * ===== SPEND =====
   */
  spend Float? @default(0)

  /**
   * ===== CONVERSION =====
   */
  results       Int?   @default(0)
  costPerResult Float? @default(0)
  aov           Int?   @default(0)

  purchases     Int?   @default(0)
  purchaseValue Float? @default(0)
  roas          Float? @default(0)

  registrationComplete      Int?   @default(0)
  registrationCompleteValue Float? @default(0)
  messagingStarted          Int?   @default(0)
  messagingStartedValue     Float? @default(0)
  outboundClicks            Int?   @default(0)
  outboundClicksValue       Float? @default(0)

  cvr          Float? @default(0)
  adsCostRatio Float? @default(0)

  qualityRanking        String?
  engagementRateRanking String?
  conversionRateRanking String?

  /**
   * ===== RAW =====
   */
  actions      Json?
  actionValues Json?

  videoPlay Float? @default(0)
  video3s   Float? @default(0)
  video100  Float? @default(0)

  videoAvgWatchTime Float? @default(0)
  videoThruplay     Int?   @default(0)
  videoView         Int?   @default(0)

  hookRate Float? @default(0)
  holdRate Float? @default(0)

  @@unique([id, systemCampaignId])
  // ✅ INDEXES
  @@index([accountId, updatedAt(sort: Desc)])
  @@index([accountId, status, updatedAt(sort: Desc)])
  @@index([accountId, remoteUpdatedAt(sort: Desc)])
  // optional (nếu dùng soft delete nhiều)
  @@index([accountId, deletedAt, updatedAt(sort: Desc)])
  // optional (nếu dùng cursor pagination)
  @@index([accountId, updatedAt(sort: Desc), id])
}

// Đánh dấu "đã xem" theo từng user cho MỌI loại entity (badge "Mới" ở danh sách).
// Đa hình: (entityType, entityId, userId) — có 1 dòng = user đã mở; không có = chưa
// xem. Ghi side-effect khi mở chi tiết (giống mốc lastReadBy của Contribution).
// Không FK (entityId đa hình) → chấp nhận orphan khi hard-delete (nhỏ, vô hại).
// Thêm entity mới chỉ cần +1 value ở SeenEntityType.
enum SeenEntityType {
  CAMPAIGN
  ADSET
  AD
  CREATIVE
}

model EntitySeen {
  entityType SeenEntityType
  entityId   String
  userId     String
  seenAt     DateTime       @default(now())

  @@id([entityType, entityId, userId])
  @@index([userId, entityType])
}

model AdSet {
  id         String   @id
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  accountId String
  account   Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  name             String?
  status           String?
  effectiveStatus  String?
  configuredStatus String?

  optimizationGoal String?
  destinationType  String?
  billingEvent     String?
  bidStrategy      String?

  effectiveBudget Int  @default(0)
  dailyBudget     Int?
  lifetimeBudget  Int?

  targeting       Json?
  startTime       DateTime?
  endTime         DateTime?
  remoteUpdatedAt DateTime?

  lastFetchedAt DateTime?
  rawPayload    Json?

  ads Ad[]

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @default(now())
  deletedAt     DateTime?
  adSetInsights AdSetInsight[]

  // INSIGHT
  // INSIGHT DATA
  impressions Int?   @default(0)
  reach       Int?   @default(0)
  frequency   Float? @default(0)

  /**
   * ===== TRAFFIC =====
   */
  clicks       Int?   @default(0)
  uniqueClicks Int?   @default(0)
  ctr          Float? @default(0)
  uniqueCtr    Float? @default(0)
  cpc          Float? @default(0)
  cpm          Float? @default(0)

  /**
   * ===== SPEND =====
   */
  spend Float? @default(0)

  /**
   * ===== CONVERSION =====
   */
  results       Int?   @default(0)
  costPerResult Float? @default(0)
  aov           Int?   @default(0)

  purchases     Int?   @default(0)
  purchaseValue Float? @default(0)
  roas          Float? @default(0)

  registrationComplete      Int?   @default(0)
  registrationCompleteValue Float? @default(0)
  messagingStarted          Int?   @default(0)
  messagingStartedValue     Float? @default(0)
  outboundClicks            Int?   @default(0)
  outboundClicksValue       Float? @default(0)

  cvr          Float? @default(0)
  adsCostRatio Float? @default(0)

  qualityRanking        String?
  engagementRateRanking String?
  conversionRateRanking String?

  /**
   * ===== RAW =====
   */
  actions      Json?
  actionValues Json?

  videoPlay Float? @default(0)
  video3s   Float? @default(0)
  video100  Float? @default(0)

  videoAvgWatchTime Float? @default(0)
  videoThruplay     Int?   @default(0)
  videoView         Int?   @default(0)

  hookRate              Float?                 @default(0)
  holdRate              Float?                 @default(0)
  adsetAudienceInsights AdsetAudienceInsight[]

  insight3dId String?       @unique
  insight3d   AdSetInsight? @relation("AdSet_3D", fields: [insight3dId], references: [id])

  insight7dId String?       @unique
  insight7d   AdSetInsight? @relation("AdSet_7D", fields: [insight7dId], references: [id])

  insightMaxId String?       @unique
  insightMax   AdSetInsight? @relation("AdSet_MAX", fields: [insightMaxId], references: [id])

  insightTodayId String?       @unique
  insightToday   AdSetInsight? @relation("AdSet_TODAY", fields: [insightTodayId], references: [id])

  // 🔥 list theo campaign
  @@index([campaignId, updatedAt(sort: Desc)])
  // 🔥 list theo account
  @@index([accountId, updatedAt(sort: Desc)])
  // 🔥 filter + sort
  @@index([accountId, status, updatedAt(sort: Desc)])
  // 🔥 sync data
  @@index([accountId, remoteUpdatedAt(sort: Desc)])
  // 🔥 soft delete (nếu dùng)
  @@index([accountId, deletedAt, updatedAt(sort: Desc)])
  // 🔥 pagination mượt
  @@index([campaignId, updatedAt(sort: Desc), id])
}

model Ad {
  id String @id

  adsetId String
  adset   AdSet  @relation(fields: [adsetId], references: [id], onDelete: Cascade)

  cid      String?
  cidGroup CidGroup? @relation(fields: [cid], references: [cid], onDelete: Cascade)

  campaignId String?
  campaign   Campaign? @relation(fields: [campaignId], references: [id])

  accountId String?
  account   Account? @relation(fields: [accountId], references: [id])

  name             String?
  status           String?
  effectiveStatus  String?
  configuredStatus String?
  creativeId       String?
  creative         Creative?       @relation(fields: [creativeId], references: [id])
  remoteUpdatedAt  DateTime?
  lastFetchedAt    DateTime?
  rawPayload       Json?
  adInsights       AdInsight[]
  fatigueState     AdFatigueState?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now())
  deletedAt DateTime?

  // INSIGHT
  // INSIGHT DATA
  impressions Int?   @default(0)
  reach       Int?   @default(0)
  frequency   Float? @default(0)

  /**
   * ===== TRAFFIC =====
   */
  clicks       Int?   @default(0)
  uniqueClicks Int?   @default(0)
  ctr          Float? @default(0)
  uniqueCtr    Float? @default(0)
  cpc          Float? @default(0)
  cpm          Float? @default(0)

  /**
   * ===== SPEND =====
   */
  spend Float? @default(0)

  /**
   * ===== CONVERSION =====
   */
  results       Int?   @default(0)
  costPerResult Float? @default(0)
  aov           Int?   @default(0)

  purchases     Int?   @default(0)
  purchaseValue Float? @default(0)
  roas          Float? @default(0)

  registrationComplete      Int?   @default(0)
  registrationCompleteValue Float? @default(0)
  messagingStarted          Int?   @default(0)
  messagingStartedValue     Float? @default(0)
  outboundClicks            Int?   @default(0)
  outboundClicksValue       Float? @default(0)

  cvr          Float? @default(0)
  adsCostRatio Float? @default(0)

  qualityRanking        String?
  engagementRateRanking String?
  conversionRateRanking String?

  /**
   * ===== RAW =====
   */
  actions      Json?
  actionValues Json?

